{
  "manifest_version": 3,
  "name": "LLM Context Capsule",
  "version": "1.0.0",
  "description": "Extracts, stores, and encapsulates LLM chat history into portable Markdown contexts.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "action": {
    "default_icon": "image.png",
    "default_popup": "popup.html",
    "default_title": "Capture Context Capsule"
  },
    "icons": {
        "16": "image.png",
        "48": "image.png",
        "128": "image.png"
    }
}